✅ Full C++ Code
cpp
#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T; cin >> T;
    while (T--) {
        int N, X; cin >> N >> X;
        vector<int> coins(N);
        for (int i = 0; i < N; i++) cin >> coins[i];

        const int INF = 1e9;
        vector<int> dp(X+1, INF);
        dp[0] = 0;

        for (int i = 1; i <= X; i++) {
            for (int c : coins) {
                if (i - c >= 0) {
                    dp[i] = min(dp[i], dp[i-c] + 1);
                }
            }
        }

        cout << (dp[X] == INF ? -1 : dp[X]) << "\n";
    }
    return 0;
}
