2. How to Think About It
This is a search problem.

Each cell is a potential starting point.

From that cell, you try to match the word letter by letter.

You must explore all possible paths → DFS (Depth‑First Search) + Backtracking.

3. Approach
Loop through every cell in the grid.

If the cell matches the first letter of the word, start DFS from there.

DFS:

If current index = word length → success.

If out of bounds or letter mismatch → fail.

Mark the cell as visited (temporarily).

Explore neighbors (up, down, left, right).

Backtrack (unmark the cell) after exploring.

If any DFS succeeds → return true.

If none succeed → return false.

4. C++ Code
cpp
#include <bits/stdc++.h>
using namespace std;

bool dfs(vector<vector<char>>& board, string& word, int i, int j, int idx) {
    if (idx == word.size()) return true; // all letters matched
    if (i < 0 || j < 0 || i >= board.size() || j >= board[0].size()) return false;
    if (board[i][j] != word[idx]) return false;

    char temp = board[i][j];
    board[i][j] = '#'; // mark visited

    bool found = dfs(board, word, i+1, j, idx+1) ||
                 dfs(board, word, i-1, j, idx+1) ||
                 dfs(board, word, i, j+1, idx+1) ||
                 dfs(board, word, i, j-1, idx+1);

    board[i][j] = temp; // backtrack
    return found;
}

bool exist(vector<vector<char>>& board, string word) {
    int m = board.size(), n = board[0].size();
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (dfs(board, word, i, j, 0)) return true;
        }
    }
    return false;
}

int main() {
    int m, n;
    cin >> m >> n;
    vector<vector<char>> board(m, vector<char>(n));
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            cin >> board[i][j];
        }
    }
    string word;
    cin >> word;
    cout << (exist(board, word) ? "true" : "false") << "\n";
    return 0;
}
