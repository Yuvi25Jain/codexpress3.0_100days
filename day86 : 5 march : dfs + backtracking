#include <bits/stdc++.h>
using namespace std;

int minMovesToUnique(vector<int>& IDs) {
    sort(IDs.begin(), IDs.end());
    long long moves = 0;   // use long long to avoid overflow
    int prev = -1;         // last fixed unique ID

    for (int i = 0; i < IDs.size(); i++) {
        if (IDs[i] <= prev) {
            // push forward to prev+1
            moves += (prev + 1 - IDs[i]);
            IDs[i] = prev + 1;
        }
        prev = IDs[i];
    }
    return (int)moves;     // guaranteed to fit in 32-bit
}

