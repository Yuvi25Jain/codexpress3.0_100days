        for (int i = 0; i < n; i++) {
            cin >> nodes[i];
        }
        int targetSum; 
        cin >> targetSum;

        TreeNode* root = buildTree(nodes);
        cout << (hasPathSum(root, targetSum) ? "true" : "false") << "\n";
    }
    return 0;
}
