class Solution {
public:
    vector<long long> distance(vector<int>& nums) {
        int n = nums.size();
        vector<long long> ans(n, 0);

        // Group indices by value
        unordered_map<int, vector<int>> groups;
        for (int i = 0; i < n; i++) {
            groups[nums[i]].push_back(i);
        }

        // Process each group
        for (auto &p : groups) {
            auto &idx = p.second;
            int m = idx.size();
            if (m == 1) continue; // only one occurrence → distance = 0

            // Prefix sums of indices
            vector<long long> prefix(m, 0);
            prefix[0] = idx[0];
            for (int i = 1; i < m; i++) {
                prefix[i] = prefix[i-1] + idx[i];
            }

            // Compute distance for each index
            for (int i = 0; i < m; i++) {
                long long left = (long long)idx[i] * i - (i > 0 ? prefix[i-1] : 0);
                long long right = (prefix[m-1] - prefix[i]) - (long long)(m - i - 1) * idx[i];
                ans[idx[i]] = left + right;
            }
        }

        return ans;
    }
};
🧩 How It Works
Grouping: Collect indices for each lantern type.

Prefix sums: Precompute sums of indices for fast left/right contributions.

Formula:

Left contribution = idx[i]*i - sum(left indices)

Right contribution = (sum(right indices)) - idx[i]*countRight

Result: O(n) time, efficient for large inputs.

