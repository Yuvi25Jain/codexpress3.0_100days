✅ Full C++ Code
cpp
#include <bits/stdc++.h>
using namespace std;

bool isPerfectSquare(long long x) {
    long long r = sqrt(x);
    return r * r == x;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T; 
    cin >> T;
    while (T--) {
        long long c; 
        cin >> c;
        bool ok = false;

        for (long long a = 0; a * a <= c; a++) {
            long long b2 = c - a * a;
            if (isPerfectSquare(b2)) {
                ok = true;
                break;
            }
        }

        cout << (ok ? "yes" : "no") << "\n";
    }
    return 0;
}
