📌 Full C++ Code
cpp
#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T; cin >> T;
    while (T--) {
        int N, W; cin >> N >> W;
        vector<int> value(N), weight(N);
        for (int i = 0; i < N; i++) {
            cin >> value[i] >> weight[i];
        }

        vector<int> dp(W+1, 0);

        for (int i = 0; i < N; i++) {
            for (int w = W; w >= weight[i]; w--) {
                dp[w] = max(dp[w], dp[w - weight[i]] + value[i]);
            }
        }

        cout << dp[W] << "\n";
    }
    return 0;
}
