Pattern: DFS + Memoization (backtracking with caching).

Why?

You need all possible sentences, not just one.

Each prefix that matches a dictionary word → recurse on the remainder.

Memoize results for substrings to avoid recomputation.

Edge cases:

Empty string → return empty list.

No valid segmentation → return empty list.

Dictionary words can be reused.

✅ One‑Shot Fixed C++ Code
cpp
#include <bits/stdc++.h>
using namespace std;

vector<string> dfs(string s, unordered_set<string>& dict, unordered_map<string, vector<string>>& memo) {
    if (memo.count(s)) return memo[s];
    vector<string> res;
    if (s.empty()) {
        res.push_back("");
        return res;
    }
    for (int len = 1; len <= (int)s.size(); len++) {
        string word = s.substr(0, len);
        if (dict.count(word)) {
            vector<string> subRes = dfs(s.substr(len), dict, memo);
            for (string sub : subRes) {
                res.push_back(word + (sub.empty() ? "" : " " + sub));
            }
        }
    }
    return memo[s] = res;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T; cin >> T;
    while (T--) {
        string S; cin >> S;
        int N; cin >> N;
        unordered_set<string> dict;
        for (int i = 0; i < N; i++) {
            string w; cin >> w;
            dict.insert(w);
        }

        unordered_map<string, vector<string>> memo;
        vector<string> ans = dfs(S, dict, memo);

        if (ans.empty()) {
            cout << "\n"; // empty line if no valid sentence
        } else {
            for (auto &sentence : ans) {
                cout << sentence << "\n";
            }
        }
    }
    return 0;
}
