class Solution {
public:
    unordered_map<string, vector<string>> memo;

    vector<string> dfs(string s, unordered_set<string>& dict) {
        if (memo.count(s)) return memo[s];
        vector<string> res;
        if (s.empty()) {
            res.push_back("");
            return res;
        }
        for (int len = 1; len <= (int)s.size(); len++) {
            string word = s.substr(0, len);
            if (dict.count(word)) {
                vector<string> subRes = dfs(s.substr(len), dict);
                for (string sub : subRes) {
                    res.push_back(word + (sub.empty() ? "" : " " + sub));
                }
            }
        }
        return memo[s] = res;
    }

    vector<string> wordBreak(string s, vector<string>& wordDict) {
        unordered_set<string> dict(wordDict.begin(), wordDict.end());
        memo.clear();
        return dfs(s, dict);
    }
};
🔑 Why This Works
DFS + memoization: explores all prefixes, caches results for substrings.

Dictionary lookup: unordered_set for O(1) prefix checks.

Sentence building: append current word + recursive remainder.

Edge cases:

Empty string → returns [""] internally, handled correctly.

No valid segmentation → returns empty vector.

